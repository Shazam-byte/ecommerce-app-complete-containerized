# ----------------------------------------------------
# AWS MULTI-TIER E-COMMERCE BACKEND CONFIGURATION (.ENV)
# ----------------------------------------------------

PORT=5000
NODE_ENV=production

# 1. MySQL Database Configuration
DB_HOST=ecommerce-db.cy7ui4i2kst2.us-east-1.rds.amazonaws.com
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=F28py5iGeSEFjxC
DB_NAME=ecommerce

# 2. JWT Authentication Secrets
JWT_SECRET=super_secret_session_token_key_for_signing_jwts
# JWT expiration (e.g., 1d, 7d)
JWT_EXPIRES_IN=7d

# 3. AWS S3 Storage Bucket Details (for product images upload)
AWS_ACCESS_KEY_ID=your_aws_iam_user_access_key
AWS_SECRET_ACCESS_KEY=your_aws_iam_user_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=ecommerce-product-images-shah

# 4. CORS Allowed Origins
# Configured so that only the decoupled React S3/CloudFront application can fetch from this server
FRONTEND_URL=http://ecommerce-frontend-shah.s3-website-us-east-1.amazonaws.com
